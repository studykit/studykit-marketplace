{
  "description": "Prevent obsidian plugin agents and skills from triggering outside an Obsidian vault",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-obsidian-vault.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-obsidian-vault.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
