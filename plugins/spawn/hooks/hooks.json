{
  "description": "Session orchestrator hooks — manage child session lifecycle via session-tree.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start_bootstrap.py\"",
            "timeout": 10,
            "description": "Initialize or resume child sessions with context from session-tree.json"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/session_end_collector.py\"",
            "timeout": 5,
            "description": "Mark child sessions as terminated when session ends"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/notification_relay.py\"",
            "timeout": 5,
            "description": "Inject queued notifications into Claude context on each user message"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "session-tree.json",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/session_monitor.py\"",
            "timeout": 10,
            "description": "Monitor child session status changes when session-tree.json is modified"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/context_drift.py\"",
            "timeout": 5,
            "description": "Detect modifications to referenced files in child sessions"
          }
        ]
      }
    ]
  }
}
